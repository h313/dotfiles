export _JAVA_OPTIONS='-Dawt.useSystemAAFontSettings=on -Dswing.aatext=true -Dswing.defaultlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel -Dswing.crossplatformlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel  -Dsun.java2d.uiScale=2 -Dhidpi=true -Dsun.java2d.dpiaware=false'
export EDITOR=vim

export QT_AUTO_SCREEN_SCALE_FACTOR=1
export GDK_SCALE=1.5
export ELM_SCALE=1.5

export NVIM_GTK_PREFER_DARK_THEME=1
export NVIM_GTK_DOUBLE_BUFFER=1

