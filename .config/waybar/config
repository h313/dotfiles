{
  "layer": "bottom",
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["sway/window"],
  "modules-right": ["pulseaudio", "battery", "clock", "tray"],
  "sway/window": {
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
  "format-bluetooth": "{icon}  {volume}%яКФ",
  "format-muted": "",
  "format-icons": {
    "headphones": "яАе",
    "default": [
      "яАз",
      "яАи"
    ]
  },
  "scroll-step": 5,
  "on-click": "alacritty -e pulsemixer"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "clock": {
    "format-alt": "{:%a, %b %d  %H:%M}"
  }
}
