[colors]
background = #1D1F21
foreground = #C5C8C6
primary = #ffb52a
alert = #bd2c40
green = #B5BD68
blue = #81A2BE
red = #CC6666
purple = #B293BB

[bar/laptop]
monitor = eDP-1
width = 100%
height = 40
;offset-x = 1%
;offset-y = 1%
radius = 0
fixed-center = false
bottom = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = #f00

padding-left = 5
padding-right = 5

module-margin-left = 2
module-margin-right = 2

font-0 = FiraMono:size=16;2
font-1 = FontAwesome:size=16;3
font-2 = siji:pixelsize=14;1

modules-left = i3
modules-right = volume battery date time

tray-position = right
tray-padding = 2
;tray-transparent = true
;tray-background = #0063ff

;wm-restack = i3

;override-redirect = true

scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

